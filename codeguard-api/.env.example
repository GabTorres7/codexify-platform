# ── Application ──────────────────────────────────────────────
APP_NAME=Codexify API
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── AI Provider ("anthropic" ou "openai") ────────────────────
AI_PROVIDER=openai

# ── Anthropic (Claude) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# ── OpenAI (GPT) ────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# ── GitHub ───────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=change-me

# ── GitLab ───────────────────────────────────────────────────
GITLAB_WEBHOOK_SECRET=change-me

# ── API Keys ─────────────────────────────────────────────────
API_KEY_PREFIX=cg_live_

# ── JWT ──────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Notifications ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
DEFAULT_FROM_EMAIL=codeguard@yourdomain.com

# ── Public API URL (for webhook registration) ─────────────────
PUBLIC_API_URL=https://your-api.onrender.com

# ── Frontend URL (Vercel deploy — usado para CORS e redirect) ─
FRONTEND_URL=https://your-app.vercel.app
